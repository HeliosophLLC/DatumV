<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>Heliosoph.DatumV.LanguageServer</PackageId>
    <RootNamespace>Heliosoph.DatumV.LanguageServer</RootNamespace>
    <AssemblyName>Heliosoph.DatumV.LanguageServer</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsTrimmable>true</IsTrimmable>
    <IsPackable>true</IsPackable>
    <Description>Transport-agnostic SQL language intelligence for the DatumV SQL dialect. Provides autocomplete, diagnostics, and hover for Monaco and VS Code integration.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
  </ItemGroup>
  
  <ItemGroup>
    <InternalsVisibleTo Include="Heliosoph.DatumV.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\..\docs\toc.yml" LogicalName="DatumIngest.LanguageServer.docs.toc.yml" />
    <EmbeddedResource Include="..\..\docs\sql\*.md" LogicalName="DatumIngest.LanguageServer.docs.sql.%(Filename).md" />
    <EmbeddedResource Include="..\..\docs\functions\*.md" LogicalName="DatumIngest.LanguageServer.docs.functions.%(Filename).md" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DatumIngest.Parsing\DatumIngest.Parsing.csproj" />
  </ItemGroup>

</Project>
