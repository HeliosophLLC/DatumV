{
  "$schema": "./catalog.schema.json",
  "_comment": [
    "DatumIngest model catalog — v1 manifest read by the in-app Model Manager",
    "and (eventually) the catalog-aware variants of scripts/download-*.ps1.",
    "",
    "Schema notes:",
    "  - `licenses` (top-level) defines each license once. Per-model `licenseIds`",
    "    references entries here. The app uses `textFile` to render acceptance UI",
    "    offline; `canonicalUrl` is the authoritative source for verification.",
    "  - `requiresAcceptance` is a property of the LICENSE (does the user have to",
    "    click 'I accept' on this license text?). MIT/Apache = false. OpenRAIL-M",
    "    and similar = true.",
    "  - `requiresHfLogin` is a property of the MODEL (is the HF source repo",
    "    gated by HuggingFace, requiring a logged-in token to download?). This is",
    "    independent of the license — Llama is both gated AND has app-acceptance.",
    "",
    "Entries marked `placeholder: true` point at huggingface.co/Heliosoph/*",
    "repos that do not exist yet — see models/upload-plan.json for the upload",
    "plan that brings them online. The downloader should treat placeholder",
    "entries as unavailable until they're cleared.",
    "",
    "Revision pinning: v1 manifest uses `revision: 'main'` for simplicity. When",
    "v2 ships, each model will be pinned to a specific commit sha so the catalog",
    "is reproducible across HF history.",
    "",
    "Verification: downloader queries HF's tree API at the specified revision,",
    "which returns lfs.sha256 per file. The manifest does NOT bake per-file",
    "hashes — they come from HF at download time."
  ],
  "schemaVersion": 1,

  "licenses": {
    "mit": {
      "title": "MIT License",
      "spdx": "MIT",
      "canonicalUrl": "https://opensource.org/license/mit",
      "textFile": "licenses/mit.txt",
      "summary": "Permissive open-source license. Allows commercial use, modification, and redistribution. Only requires preserving the original copyright notice.",
      "requiresAcceptance": false
    },
    "apache-2.0": {
      "title": "Apache License 2.0",
      "spdx": "Apache-2.0",
      "canonicalUrl": "https://www.apache.org/licenses/LICENSE-2.0",
      "textFile": "licenses/apache-2.0.txt",
      "summary": "Permissive open-source license with an explicit patent grant. Allows commercial use, modification, and redistribution. Requires preserving copyright/notice/attribution.",
      "requiresAcceptance": false
    },
    "cc-by-4.0": {
      "title": "Creative Commons Attribution 4.0 International",
      "spdx": "CC-BY-4.0",
      "canonicalUrl": "https://creativecommons.org/licenses/by/4.0/legalcode",
      "textFile": "licenses/cc-by-4.0.txt",
      "summary": "Permissive license. Allows commercial use, modification, and redistribution. Requires attribution to the original author.",
      "requiresAcceptance": false
    },
    "creativeml-openrail-m": {
      "title": "CreativeML OpenRAIL-M License",
      "spdx": "CreativeML-OpenRAIL-M",
      "canonicalUrl": "https://huggingface.co/spaces/CompVis/stable-diffusion-license",
      "textFile": "licenses/creativeml-openrail-m.md",
      "summary": "Open license with use-based restrictions. Commercial use OK. Prohibits CSAM, discrimination, automated legal/medical decision-making, misinformation generation, and similar misuse. Used by SD 1.x and its fine-tunes.",
      "requiresAcceptance": true
    },
    "creativeml-openrail-pp-m": {
      "title": "CreativeML OpenRAIL++-M License",
      "spdx": "CreativeML-OpenRAIL-Plus-Plus-M",
      "canonicalUrl": "https://huggingface.co/stabilityai/stable-diffusion-xl-base-1.0/blob/main/LICENSE.md",
      "textFile": "licenses/creativeml-openrail-pp-m.md",
      "summary": "Stability AI variant of OpenRAIL-M for SDXL. Same use-based restrictions as OpenRAIL-M with tightened attribution clauses. Used by SDXL base and SDXL fine-tunes.",
      "requiresAcceptance": true
    },
    "llama-3.1-community": {
      "title": "Llama 3.1 Community License",
      "spdx": "Llama-3.1-Community",
      "canonicalUrl": "https://www.llama.com/llama3_1/license/",
      "textFile": "licenses/llama-3.1-community.md",
      "summary": "Source-available license from Meta. Allows commercial use BELOW 700 million monthly active users (above requires a separate Meta license). Requires 'Built with Llama' attribution and prefixing derivative model names with 'Llama'. Subject to Meta's Acceptable Use Policy.",
      "requiresAcceptance": true
    }
  },

