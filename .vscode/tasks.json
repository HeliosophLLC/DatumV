{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Debug: Build IndexOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/IndexOnce",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Debug: Build IngestOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/IngestOnce",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Release: Build Solution",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"DatumIngest.slnx",
				"-c", "Release"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Pack NuGet (Local)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"pack",
				"DatumIngest.slnx",
				"-c",
				"Release",
				"-o",
				"${env:USERPROFILE}/.nuget/local"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Trace: CPU + GC",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy", "Bypass",
				"-File", "tools\\trace.ps1",
				"-Tool", "${input:traceTool}"
			],
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
	],
	"inputs": [
		{
			"id": "traceTool",
			"type": "pickString",
			"description": "Which tool to trace",
			"options": ["IngestOnce", "IndexOnce", "ReadCsv"],
			"default": "IndexOnce"
		}
	]
}
