{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Pack NuGet (Local)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"pack",
				"DatumIngest.slnx",
				"-c",
				"Release",
				"-o",
				"${env:USERPROFILE}/.nuget/local"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Docs Site: Build & Serve (Docker)",
			"type": "shell",
			"command": "docker",
			"args": [
				"build",
				"-f", "docs-site/Dockerfile",
				"-t", "datumingest-docs",
				"."
			],
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Docs Site: Run (Docker)",
			"type": "shell",
			"command": "docker",
			"args": [
				"run",
				"--rm",
				"-p", "4000:4000",
				"-p", "35729:35729",
				"--name", "datumingest-docs",
				"datumingest-docs"
			],
			"dependsOn": "Docs Site: Build & Serve (Docker)",
			"problemMatcher": [],
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Docs Site: Rebuild & Run (Docker)",
			"type": "shell",
			"command": "docker",
			"args": [
				"rm", "-f", "datumingest-docs"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent"
			},
			"dependsOrder": "sequence",
			"dependsOn": [],
			"hide": true
		},
		{
			"label": "Docs Site: Start",
			"dependsOrder": "sequence",
			"dependsOn": [
				"Docs Site: Rebuild & Run (Docker)",
				"Docs Site: Run (Docker)"
			],
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"reveal": "always"
			}
		},
		{
			"label": "Docs Site: Stop",
			"type": "shell",
			"command": "docker",
			"args": [
				"rm", "-f", "datumingest-docs"
			],
			"problemMatcher": [],
			"group": "build"
		}
	]
}