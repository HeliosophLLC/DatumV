{
	"version": "2.0.0",
	"tasks": [
		{
			// Full dev launch: Vite + Electron + .NET (Electron spawns
			// dotnet itself). -NoProfile avoids the workspace .venv
			// auto-activation that the Python extension injects into
			// fresh terminals; isBackground keeps the task panel in
			// "running" state so VS Code doesn't treat the long-lived
			// concurrently process as a failure.
			//
			// Run via: Ctrl+Shift+P → "Tasks: Run Task" → this label.
			// Stop via: the trash icon on the task panel terminal,
			// which kills concurrently and (via --kill-others-on-fail)
			// vite + electron + the dotnet child.
			"label": "Dev: Electron + Backend",
			"type": "shell",
			"command": "npm",
			"args": ["run", "electron:dev"],
			"options": {
				"cwd": "${workspaceFolder}/src/Heliosoph.DatumV.Web/electron",
				"shell": {
					"executable": "powershell.exe",
					"args": ["-NoProfile", "-Command"]
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			// Background matcher signals "ready" to F5 / preLaunchTask once
			// the .NET backend prints its listening URL — by that point
			// Vite is up (concurrently sequenced electron after wait-on)
			// and Electron's BrowserWindow is loading the SPA.
			//
			// The pattern uses a compile-error-shaped regex with capture
			// groups so VS Code accepts the matcher as well-formed; our
			// dev output never emits "file(line): error" lines so no
			// spurious problems land in the Problems panel.
			"problemMatcher": {
				"owner": "dev-electron",
				"pattern": {
					"regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(.*)$",
					"file": 1,
					"location": 2,
					"severity": 3,
					"message": 4
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "Heliosoph.DatumV listening at"
				}
			}
		},
		{
			// Release variant of "Dev: Electron + Backend". Same Vite +
			// Electron pipeline, but DOTNET_CONFIGURATION=Release flips the
			// spawned .NET backend out of Debug — POOL_DIAGNOSTICS is gated
			// to Debug, so per-pool-return stack-trace capture (which can
			// dominate allocation traces) goes away. Use this when measuring
			// memory / CPU under realistic conditions.
			"label": "Release: Electron + Backend",
			"type": "shell",
			"command": "npm",
			"args": ["run", "electron:dev"],
			"options": {
				"cwd": "${workspaceFolder}/src/Heliosoph.DatumV.Web/electron",
				"env": {
					"DOTNET_CONFIGURATION": "Release"
				},
				"shell": {
					"executable": "powershell.exe",
					"args": ["-NoProfile", "-Command"]
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"problemMatcher": {
				"owner": "dev-electron",
				"pattern": {
					"regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(.*)$",
					"file": 1,
					"location": 2,
					"severity": 3,
					"message": 4
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "Heliosoph.DatumV listening at"
				}
			}
		},
		{
			"label": "Debug: Build IndexOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/IndexOnce",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Debug: Build IngestOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/IngestOnce",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Release: Build Solution",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"Heliosoph.DatumV.slnx",
				"-c", "Release"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Pack NuGet (Local)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"pack",
				"Heliosoph.DatumV.slnx",
				"-c",
				"Release",
				"-o",
				"${env:USERPROFILE}/.nuget/local"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Trace: CPU + GC",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy", "Bypass",
				"-File", "tools\\trace.ps1",
				"-Tool", "${input:traceTool}",
				"-Sql", "${input:traceSql}"
			],
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Debug: Build IndexInspect",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/IndexInspect",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Run: IndexInspect (summary)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project", "tools/IndexInspect",
				"-c", "Debug",
				"--no-build",
				"--",
				"${input:indexPath}"
			],
			"dependsOn": "Debug: Build IndexInspect",
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Run: IndexInspect (distinct)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project", "tools/IndexInspect",
				"-c", "Debug",
				"--no-build",
				"--",
				"${input:indexPath}",
				"--distinct", "${input:indexColumn}"
			],
			"dependsOn": "Debug: Build IndexInspect",
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Run: IndexInspect (vocab)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project", "tools/IndexInspect",
				"-c", "Debug",
				"--no-build",
				"--",
				"${input:indexPath}",
				"--vocab", "${input:indexColumn}"
			],
			"dependsOn": "Debug: Build IndexInspect",
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Debug: Build ExplainOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/ExplainOnce",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Debug: Build ExecuteOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/ExecuteOnce",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Release: Build ExecuteOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/ExecuteOnce",
				"-c", "Release"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Debug: Build Web",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"src/Heliosoph.DatumV.Web",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Release: Build Web",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"src/Heliosoph.DatumV.Web",
				"-c", "Release"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Run: ExplainOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project", "tools/ExplainOnce",
				"-c", "Debug",
				"--no-build",
				"--",
				"${input:datumPath}",
				"${input:explainSql}"
			],
			"dependsOn": "Debug: Build ExplainOnce",
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Debug: Build SidecarInspect",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/SidecarInspect",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Run: SidecarInspect",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project", "tools/SidecarInspect",
				"-c", "Debug",
				"--no-build",
				"--",
				"${input:sidecarPath}"
			],
			"dependsOn": "Debug: Build SidecarInspect",
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Test: Run filtered",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"--no-restore",
				"--filter",
				"${input:testFilter}"
			],
			"problemMatcher": [],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "Test: Run all (excluding allocation)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"--no-restore",
				"--filter",
				"FullyQualifiedName!~Allocation"
			],
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			}
		},
	],
	"inputs": [
		{
			"id": "traceTool",
			"type": "pickString",
			"description": "Which tool to trace",
			"options": ["IngestOnce", "IndexOnce", "ExecuteOnce"],
			"default": "IndexOnce"
		},
		{
			"id": "traceSql",
			"type": "promptString",
			"description": "SQL to execute (ExecuteOnce only; ignored for other tools)",
			"default": "SELECT * LIMIT 5000"
		},
		{
			"id": "indexPath",
			"type": "promptString",
			"description": "Path to .datum-index file"
		},
		{
			"id": "indexColumn",
			"type": "promptString",
			"description": "Column name to extract"
		},
		{
			"id": "datumPath",
			"type": "promptString",
			"description": "Path to .datum file"
		},
		{
			"id": "explainSql",
			"type": "promptString",
			"description": "SQL to explain (quote spaces)"
		},
		{
			"id": "sidecarPath",
			"type": "promptString",
			"description": "Path to a .datum or .datum-blob file (sidecar resolved automatically)"
		},
		{
			"id": "testFilter",
			"type": "promptString",
			"description": "Test filter (e.g. 'FullyQualifiedName~Image', 'FullyQualifiedName~SidecarStoreTests', 'Category!=Slow')",
			"default": "FullyQualifiedName~"
		}
	]
}
