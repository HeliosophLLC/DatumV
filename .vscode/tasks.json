{
	"version": "2.0.0",
	"tasks": [
		{
			// Full dev launch: Vite + Electron + .NET (Electron spawns
			// dotnet itself). -NoProfile avoids the workspace .venv
			// auto-activation that the Python extension injects into
			// fresh terminals; isBackground keeps the task panel in
			// "running" state so VS Code doesn't treat the long-lived
			// concurrently process as a failure.
			//
			// Run via: Ctrl+Shift+P → "Tasks: Run Task" → this label.
			// Stop via: the trash icon on the task panel terminal,
			// which kills concurrently and (via --kill-others-on-fail)
			// vite + electron + the dotnet child.
			"label": "Dev: Electron + Backend",
			"type": "shell",
			"command": "npm",
			"args": ["run", "electron:dev"],
			"options": {
				"cwd": "${workspaceFolder}/src/Heliosoph.DatumV.Web/electron",
				"shell": {
					"executable": "powershell.exe",
					"args": ["-NoProfile", "-Command"]
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			// Background matcher signals "ready" to F5 / preLaunchTask once
			// the .NET backend prints its listening URL — by that point
			// Vite is up (concurrently sequenced electron after wait-on)
			// and Electron's BrowserWindow is loading the SPA.
			//
			// The pattern uses a compile-error-shaped regex with capture
			// groups so VS Code accepts the matcher as well-formed; our
			// dev output never emits "file(line): error" lines so no
			// spurious problems land in the Problems panel.
			"problemMatcher": {
				"owner": "dev-electron",
				"pattern": {
					"regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(.*)$",
					"file": 1,
					"location": 2,
					"severity": 3,
					"message": 4
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "Heliosoph.DatumV listening at"
				}
			}
		},
		{
			// Release variant of "Dev: Electron + Backend". Same Vite +
			// Electron pipeline, but DOTNET_CONFIGURATION=Release flips the
			// spawned .NET backend out of Debug — POOL_DIAGNOSTICS is gated
			// to Debug, so per-pool-return stack-trace capture (which can
			// dominate allocation traces) goes away. Use this when measuring
			// memory / CPU under realistic conditions.
			"label": "Release: Electron + Backend",
			"type": "shell",
			"command": "npm",
			"args": ["run", "electron:dev"],
			"options": {
				"cwd": "${workspaceFolder}/src/Heliosoph.DatumV.Web/electron",
				"env": {
					"DOTNET_CONFIGURATION": "Release"
				},
				"shell": {
					"executable": "powershell.exe",
					"args": ["-NoProfile", "-Command"]
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"problemMatcher": {
				"owner": "dev-electron",
				"pattern": {
					"regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(.*)$",
					"file": 1,
					"location": 2,
					"severity": 3,
					"message": 4
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "Heliosoph.DatumV listening at"
				}
			}
		},
		{
			// CUDA variant of "Release: Electron + Backend". Same Vite +
			// Electron pipeline and Release .NET config, but GpuVariant=cuda
			// is read by MSBuild as a property when Electron spawns
			// `dotnet run` (see startDotnetBackend in main.ts), swapping the
			// default cross-vendor standard stack (ORT.DirectML + Vulkan) for
			// the NVIDIA-only stack (ORT.Gpu + LLamaSharp.Backend.Cuda12).
			//
			// First run after switching variants triggers a NuGet restore of
			// the ~500 MB CUDA package graph and rewrites packages.lock.json
			// in the working tree — discard that with
			// `git checkout -- '**/packages.lock.json'` when done (see
			// CONTRIBUTING.md). Requires the CUDA toolkit / runtime libs to
			// be resolvable (installed CUDA bundle or system CUDA on PATH);
			// otherwise the CUDA execution provider falls back to CPU.
			"label": "Release: Electron + Backend (CUDA)",
			"type": "shell",
			"command": "npm",
			"args": ["run", "electron:dev"],
			"options": {
				"cwd": "${workspaceFolder}/src/Heliosoph.DatumV.Web/electron",
				"env": {
					"DOTNET_CONFIGURATION": "Release",
					"GpuVariant": "cuda"
				},
				"shell": {
					"executable": "powershell.exe",
					"args": ["-NoProfile", "-Command"]
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"problemMatcher": {
				"owner": "dev-electron",
				"pattern": {
					"regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(.*)$",
					"file": 1,
					"location": 2,
					"severity": 3,
					"message": 4
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "Heliosoph.DatumV listening at"
				}
			}
		},
		{
			// Builds the Linux x64 CUDA AppImage from Windows by delegating
			// to WSL (Ubuntu-24.04, root). The script stashes Windows
			// node_modules, runs Linux npm ci, dotnet publish, and
			// electron-builder, then restores Windows node_modules on
			// exit (success or failure). cwd is set to electron/ so
			// wsl.exe inherits the mounted path and the script runs
			// relative. Output streams into this task's terminal —
			// closing the terminal kills the build.
			//
			// Prereqs (one-time): WSL distro Ubuntu-24.04 with .NET 10 SDK,
			// Node 22, libfuse2t64, fakeroot, bzip2. See the build script.
			"label": "Release: Build Linux AppImage (CUDA, WSL)",
			"type": "shell",
			"command": "wsl",
			"args": [
				"-d", "Ubuntu-24.04",
				"-u", "root",
				"--",
				"bash", "./.wsl-linux-build.sh"
			],
			"options": {
				"cwd": "${workspaceFolder}/src/Heliosoph.DatumV.Web/electron"
			},
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "Release: Build Solution",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"Heliosoph.DatumV.slnx",
				"-c", "Release"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Pack NuGet (Local)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"pack",
				"Heliosoph.DatumV.slnx",
				"-c",
				"Release",
				"-o",
				"${env:USERPROFILE}/.nuget/local"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Trace: CPU + GC",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy", "Bypass",
				"-File", "tools\\trace.ps1",
				"-Tool", "${input:traceTool}",
				"-Sql", "${input:traceSql}"
			],
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Debug: Build IndexInspect",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/IndexInspect",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Run: IndexInspect (summary)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project", "tools/IndexInspect",
				"-c", "Debug",
				"--no-build",
				"--",
				"${input:indexPath}"
			],
			"dependsOn": "Debug: Build IndexInspect",
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Run: IndexInspect (distinct)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project", "tools/IndexInspect",
				"-c", "Debug",
				"--no-build",
				"--",
				"${input:indexPath}",
				"--distinct", "${input:indexColumn}"
			],
			"dependsOn": "Debug: Build IndexInspect",
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Run: IndexInspect (vocab)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project", "tools/IndexInspect",
				"-c", "Debug",
				"--no-build",
				"--",
				"${input:indexPath}",
				"--vocab", "${input:indexColumn}"
			],
			"dependsOn": "Debug: Build IndexInspect",
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Debug: Build ExecuteOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/ExecuteOnce",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Release: Build ExecuteOnce",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/ExecuteOnce",
				"-c", "Release"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Debug: Build Web",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"src/Heliosoph.DatumV.Web",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Release: Build Web",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"src/Heliosoph.DatumV.Web",
				"-c", "Release"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Debug: Build SidecarInspect",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"tools/SidecarInspect",
				"-c", "Debug"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"hide": true
		},
		{
			"label": "Run: SidecarInspect",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project", "tools/SidecarInspect",
				"-c", "Debug",
				"--no-build",
				"--",
				"${input:sidecarPath}"
			],
			"dependsOn": "Debug: Build SidecarInspect",
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Test: Run filtered",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"--no-restore",
				"--filter",
				"${input:testFilter}"
			],
			"problemMatcher": [],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "Test: Run all (excluding allocation)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"--no-restore",
				"--filter",
				"FullyQualifiedName!~Allocation"
			],
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			// Stages the /docs, /models, /datasets corpora into site/ (pages,
			// search indexes, _data, copied images). Hidden helper; "Site:
			// Serve" runs it first via dependsOn. Safe to run standalone after
			// editing source docs or a catalog.
			"label": "Site: Stage content",
			"type": "shell",
			"command": "ruby",
			"args": ["scripts/build-site.rb"],
			"options": { "cwd": "${workspaceFolder}" },
			"problemMatcher": [],
			"presentation": { "reveal": "silent", "panel": "shared" },
			"hide": true
		},
		{
			// Start the static site locally at http://localhost:4000/DatumV/.
			// Stages content first, then runs the globally-installed Jekyll.
			// JEKYLL_NO_BUNDLER_REQUIRE bypasses Bundler so no `bundle install`
			// (and no Windows-only wdm C-extension build) is needed for local
			// preview; CI builds through Bundler on Linux instead.
			//
			// Run via: Ctrl+Shift+P -> "Tasks: Run Task" -> "Site: Serve".
			// Stop via: "Site: Stop" (or the trash icon on this terminal).
			"label": "Site: Serve",
			"type": "shell",
			"command": "jekyll",
			"args": ["serve", "--host", "127.0.0.1", "--port", "4000", "--livereload"],
			"dependsOn": "Site: Stage content",
			"options": {
				"cwd": "${workspaceFolder}/site",
				"env": { "JEKYLL_NO_BUNDLER_REQUIRE": "true" },
				"shell": {
					"executable": "powershell.exe",
					"args": ["-NoProfile", "-Command"]
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			// Well-formed compile-error regex (never matched by Jekyll output)
			// paired with a background matcher that flips to "ready" once
			// Jekyll prints its serving line.
			"problemMatcher": {
				"owner": "jekyll-serve",
				"pattern": {
					"regexp": "^([^\\s].*)\\((\\d+),(\\d+)\\):\\s+(error|warning)\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"severity": 4,
					"message": 5
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "Server running"
				}
			}
		},
		{
			// Stop the local Jekyll server by killing whatever is listening on
			// port 4000. Idempotent — reports if nothing is running.
			"label": "Site: Stop",
			"type": "shell",
			"command": "$c = Get-NetTCPConnection -LocalPort 4000 -State Listen -ErrorAction SilentlyContinue; if ($c) { $c.OwningProcess | Select-Object -Unique | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue }; 'Stopped site server on port 4000.' } else { 'Site server not running.' }",
			"options": {
				"shell": {
					"executable": "powershell.exe",
					"args": ["-NoProfile", "-Command"]
				}
			},
			"problemMatcher": [],
			"presentation": { "reveal": "always", "panel": "shared", "clear": true }
		}
	],
	"inputs": [
		{
			"id": "traceTool",
			"type": "pickString",
			"description": "Which tool to trace",
			"options": ["ExecuteOnce"],
			"default": "ExecuteOnce"
		},
		{
			"id": "traceSql",
			"type": "promptString",
			"description": "SQL to execute (ExecuteOnce only; ignored for other tools)",
			"default": "SELECT * LIMIT 5000"
		},
		{
			"id": "indexPath",
			"type": "promptString",
			"description": "Path to .datum-index file"
		},
		{
			"id": "indexColumn",
			"type": "promptString",
			"description": "Column name to extract"
		},
		{
			"id": "datumPath",
			"type": "promptString",
			"description": "Path to .datum file"
		},
		{
			"id": "explainSql",
			"type": "promptString",
			"description": "SQL to explain (quote spaces)"
		},
		{
			"id": "sidecarPath",
			"type": "promptString",
			"description": "Path to a .datum or .datum-blob file (sidecar resolved automatically)"
		},
		{
			"id": "testFilter",
			"type": "promptString",
			"description": "Test filter (e.g. 'FullyQualifiedName~Image', 'FullyQualifiedName~SidecarStoreTests', 'Category!=Slow')",
			"default": "FullyQualifiedName~"
		}
	]
}
