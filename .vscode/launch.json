{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "IndexOnce: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/IndexOnce/bin/Debug/net10.0/index-once.dll",
			"args": [
				"${input:datumFile}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build IndexOnce"
		},
		{
			"name": "IngestOnce: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/IngestOnce/bin/Debug/net10.0/ingest-once.dll",
			"args": [
				"${input:sourceFile}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build IngestOnce"
		},
		{
			"name": "ExecuteOnce: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/ExecuteOnce/bin/Debug/net10.0/execute-once.dll",
			"args": [
				"${input:executeDatumFile}",
				"${input:executeSql}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build ExecuteOnce"
		},
		{
			"name": "ExplainOnce: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/ExplainOnce/bin/Debug/net10.0/explain-once.dll",
			"args": [
				"${input:explainDatumFile}",
				"${input:explainOnceSql}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build ExplainOnce"
		},
		{
			"name": "ExecuteOnce: Release (Ctrl+F5 for perf)",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/ExecuteOnce/bin/Release/net10.0/execute-once.dll",
			"args": [
				"${input:executeDatumFile}",
				"${input:executeSql}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Release: Build ExecuteOnce"
		},
		{
			"name": "Shell: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/src/DatumIngest.Shell/bin/Debug/net10.0/datum-shell.dll",
			"args": [
				"${input:shellDatumPath}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build Shell"
		},
		{
			"name": "Shell: Release",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/src/DatumIngest.Shell/bin/Release/net10.0/datum-shell.dll",
			"args": [
				"${input:shellDatumPath}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Release: Build Shell"
		},
		{
			"name": "DevWeb: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/src/DatumIngest.DevWeb/bin/Debug/net10.0/datum-devweb.dll",
			"args": [
				"--port", "${input:devWebPort}",
				"${input:devWebDataPath}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"serverReadyAction": {
				"action": "openExternally",
				"pattern": "DatumIngest DevWeb listening on (https?://\\S+)"
			},
			"preLaunchTask": "Debug: Build DevWeb"
		},
		{
			"name": "App: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/src/DatumIngest.Web/bin/Debug/net10.0/datum.dll",
			"args": [],
			// cwd is the binary directory rather than the workspace root.
			// Photino's WebView2 picks its user-data folder relative to the
			// process cwd; rooting it under the workspace dropped it next to
			// node_modules / .git / heavy file-watchers, which intermittently
			// fatals WebView2 during init. Pinning to bin/ matches what a
			// double-click on datum.exe gives you.
			"cwd": "${workspaceFolder}/src/DatumIngest.Web/bin/Debug/net10.0",
			// internalConsole — VSCode's Debug Console captures stdio.
			// Avoids integratedTerminal, which runs the user's PowerShell
			// profile (including .venv activation) before our process boots.
			"console": "internalConsole",
			"justMyCode": false,
			"stopAtEntry": false,
			"env": {
				"ASPNETCORE_ENVIRONMENT": "Development"
			},
			"preLaunchTask": "Debug: Build Web"
		},
		{
			"name": "App: Debug (prod-style)",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/src/DatumIngest.Web/bin/Debug/net10.0/datum.dll",
			"args": [],
			"cwd": "${workspaceFolder}/src/DatumIngest.Web/bin/Debug/net10.0",
			"console": "internalConsole",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build Web"
		},
		{
			"name": "App: Release",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/src/DatumIngest.Web/bin/Release/net10.0/datum.dll",
			"args": [],
			"cwd": "${workspaceFolder}/src/DatumIngest.Web/bin/Release/net10.0",
			"console": "internalConsole",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Release: Build Web"
		},
		{
			"name": "DevWeb: Release",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/src/DatumIngest.DevWeb/bin/Release/net10.0/datum-devweb.dll",
			"args": [
				"--port", "${input:devWebPort}",
				"${input:devWebDataPath}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"serverReadyAction": {
				"action": "openExternally",
				"pattern": "DatumIngest DevWeb listening on (https?://\\S+)"
			},
			"preLaunchTask": "Release: Build DevWeb"
		},
	],
	"inputs": [
		{
			"id": "datumFile",
			"type": "promptString",
			"description": "Path to the .datum file to index (dest derived as .datum-index alongside)",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.datum"
		},
		{
			"id": "sourceFile",
			"type": "promptString",
			"description": "Path to the source file to ingest (CSV, ZIP, IDX, etc.)",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.csv"
		},
		{
			"id": "executeDatumFile",
			"type": "promptString",
			"description": "Path to the .datum file to query",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.datum"
		},
		{
			"id": "executeSql",
			"type": "promptString",
			"description": "SQL to execute (quote spaces)",
			"default": "SELECT * LIMIT 10"
		},
		{
			"id": "explainDatumFile",
			"type": "promptString",
			"description": "Path to the .datum file to plan",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.datum"
		},
		{
			"id": "explainOnceSql",
			"type": "promptString",
			"description": "SQL to explain (quote spaces)",
			"default": "SELECT * LIMIT 10"
		},
		{
			"id": "shellDatumPath",
			"type": "promptString",
			"description": "Path to a .datum file or directory of .datum files",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.datum"
		},
		{
			"id": "devWebDataPath",
			"type": "promptString",
			"description": "Path to a .datum file or directory of .datum files",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.datum"
		},
		{
			"id": "devWebPort",
			"type": "promptString",
			"description": "HTTP port for the DevWeb server",
			"default": "5005"
		}
	]
}
