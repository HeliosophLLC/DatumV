{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Shell: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/src/DatumIngest.Cli/bin/Debug/net10.0/win-x64/DatumIngest.Cli.dll",
			"args": [
				"shell",
				"--source", "${input:sourceDirectory}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"preLaunchTask": "Debug: Build CLI"
		}
	],
	"inputs": [
		{
			"id": "sourceDirectory",
			"type": "promptString",
			"description": "Path to the directory containing .datum files",
			"default": "E:\\Datasets\\019d5610-9245-70c1-9fbf-038e7addb609"
		}
	]
}
