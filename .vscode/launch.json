{
	"version": "0.2.0",
	"configurations": [
		{
			// F5 → runs the Dev: Electron + Backend task, which starts
			// Vite + Electron + the .NET backend with a clean PowerShell
			// (-NoProfile, no venv auto-activation, no debugger attach).
			// The task is the real work; this launch body is a no-op
			// that closes immediately after the task signals "ready".
			//
			// Shift+F5 stops only the (already-ended) debug session.
			// To kill the dev environment, click the trash icon on the
			// "Dev: Electron + Backend" task terminal.
			"name": "App: Dev (F5)",
			"type": "node-terminal",
			"request": "launch",
			"command": "exit 0",
			"preLaunchTask": "Dev: Electron + Backend"
		},
		{
			// Same as "App: Dev (F5)" but spawns the .NET backend with
			// -c Release via DOTNET_CONFIGURATION=Release set in the
			// preLaunchTask. Use when measuring allocation / memory
			// behaviour — POOL_DIAGNOSTICS is Debug-only, and the per-
			// pool-return stack-trace capture it enables can dominate
			// realistic allocation profiles otherwise.
			"name": "App: Release",
			"type": "node-terminal",
			"request": "launch",
			"command": "exit 0",
			"preLaunchTask": "Release: Electron + Backend"
		},
		{
			"name": "IndexOnce: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/IndexOnce/bin/Debug/net10.0/index-once.dll",
			"args": [
				"${input:datumFile}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build IndexOnce"
		},
		{
			"name": "IngestOnce: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/IngestOnce/bin/Debug/net10.0/ingest-once.dll",
			"args": [
				"${input:sourceFile}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build IngestOnce"
		},
		{
			"name": "ExecuteOnce: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/ExecuteOnce/bin/Debug/net10.0/execute-once.dll",
			"args": [
				"${input:executeDatumFile}",
				"${input:executeSql}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build ExecuteOnce"
		},
		{
			"name": "ExplainOnce: Debug",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/ExplainOnce/bin/Debug/net10.0/explain-once.dll",
			"args": [
				"${input:explainDatumFile}",
				"${input:explainOnceSql}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Debug: Build ExplainOnce"
		},
		{
			"name": "ExecuteOnce: Release (Ctrl+F5 for perf)",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/tools/ExecuteOnce/bin/Release/net10.0/execute-once.dll",
			"args": [
				"${input:executeDatumFile}",
				"${input:executeSql}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"justMyCode": false,
			"stopAtEntry": false,
			"preLaunchTask": "Release: Build ExecuteOnce"
		},
	],
	"inputs": [
		{
			"id": "datumFile",
			"type": "promptString",
			"description": "Path to the .datum file to index (dest derived as .datum-index alongside)",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.datum"
		},
		{
			"id": "sourceFile",
			"type": "promptString",
			"description": "Path to the source file to ingest (CSV, ZIP, IDX, etc.)",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.csv"
		},
		{
			"id": "executeDatumFile",
			"type": "promptString",
			"description": "Path to the .datum file to query",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.datum"
		},
		{
			"id": "executeSql",
			"type": "promptString",
			"description": "SQL to execute (quote spaces)",
			"default": "SELECT * LIMIT 10"
		},
		{
			"id": "explainDatumFile",
			"type": "promptString",
			"description": "Path to the .datum file to plan",
			"default": "E:\\Datasets\\Chicago Crimes Dataset\\Crimes_-_2001_to_Present_20260331.datum"
		},
		{
			"id": "explainOnceSql",
			"type": "promptString",
			"description": "SQL to explain (quote spaces)",
			"default": "SELECT * LIMIT 10"
		},
	]
}
